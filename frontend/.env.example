# Frontend Environment Variables
# Copy this to .env.local for local development, or set on your hosting platform

# Backend API URL (update to your real hosted backend URL for production)
VITE_API_URL=http://localhost:5000

# PayPal Client ID (use your live PayPal client ID for production)
# For sandbox testing, leave as 'test' or use your sandbox client ID
VITE_PAYPAL_CLIENT_ID=test
